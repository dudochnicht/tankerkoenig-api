{
  "name": "dudochnicht/tankerkoenig-api",
  "version": "1.0.0",
  "type": "library",
  "description": "A PHP client library for the Tankerkoenig API to retrieve gas station data, prices and details based on location.",
  "keywords": [
    "tankerkoenig",
    "gas-station",
    "fuel-prices",
    "api-client",
    "psr-18"
  ],
  "homepage": "https://github.com/dudochnicht/tankerkoenig-api",
  "license": "MIT",
  "authors": [
    {
      "name": "Christian Schaefer",
      "homepage": "https://github.com/dudochnicht"
    }
  ],
  "require": {
    "php": "^8.2",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0",
    "psr/log": "^3.0",
    "symfony/dotenv": "^7.4"
  },
  "require-dev": {
    "monolog/monolog": "^3.10",
    "nyholm/psr7": "^1.8",
    "symfony/http-client": "^7.0",
    "phpstan/phpstan": "^2.2",
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "files": [],
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "classmap-authoritative": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": false
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "scripts": {
    "phpunit": "phpunit",
    "phpstan": "phpstan analyse",
    "install:prod": "composer install --no-dev --optimize-autoloader --classmap-authoritative"
  }
}
